<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.hermes.dailybriefing</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/USERNAME/Hermes_Brain/.venv/bin/python</string>
        <string>-u</string>
        <string>-m</string>
        <string>scripts.daily_briefing</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/USERNAME/Hermes_Brain</string>

    <key>StartCalendarInterval</key>
    <dict>
        <key>Hour</key>
        <integer>8</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>RunAtLoad</key>
    <false/>

    <key>StandardOutPath</key>
    <string>/Users/USERNAME/Hermes_Brain/memory/logs/daily_briefing.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/USERNAME/Hermes_Brain/memory/logs/daily_briefing.log</string>
</dict>
</plist>
